<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lost & Found</title>

<style>
body {
    margin: 0;
    font-family: 'Segoe UI', sans-serif;
    background: linear-gradient(135deg, #74ebd5, #ACB6E5);
}

.container {
    max-width: 1000px;
    margin: auto;
    padding: 20px;
}

h1 {
    text-align: center;
}

.tabs {
    display: flex;
    justify-content: center;
    margin-bottom: 20px;
}

.tabs button {
    padding: 10px 20px;
    border: none;
    background: white;
    cursor: pointer;
    font-weight: bold;
    border-radius: 20px;
    margin: 5px;
}

.tabs button.active {
    background: #4CAF50;
    color: white;
}

.form-section {
    background: white;
    padding: 20px;
    border-radius: 15px;
    box-shadow: 0 5px 15px rgba(0,0,0,0.1);
}

input, textarea {
    width: 100%;
    padding: 10px;
    margin: 8px 0;
    border-radius: 10px;
    border: 1px solid #ccc;
}

.preview {
    width: 100%;
    max-height: 200px;
    margin-top: 10px;
    border-radius: 10px;
    display: none;
}

button.submit-btn {
    width: 100%;
    padding: 12px;
    background: #4CAF50;
    color: white;
    border: none;
    border-radius: 10px;
    cursor: pointer;
}

.cards {
    margin-top: 30px;
}

.card {
    background: white;
    padding: 15px;
    margin-bottom: 15px;
    border-radius: 12px;
    box-shadow: 0 3px 10px rgba(0,0,0,0.1);
    border-left: 6px solid #4CAF50;
}

.card.found {
    border-left-color: #2196F3;
}

.card img {
    width: 100%;
    border-radius: 10px;
    margin-top: 10px;
}

.delete-btn {
    background: #f44336;
    color: white;
    border: none;
    padding: 8px 12px;
    border-radius: 8px;
    margin-top: 10px;
    cursor: pointer;
}

.small {
    font-size: 12px;
    color: gray;
}
</style>
</head>

<body>

<div class="container">
    <h1>🔍 Lost & Found</h1>

    <div class="tabs">
        <button onclick="setType('lost')" id="lostBtn" class="active">Lost</button>
        <button onclick="setType('found')" id="foundBtn">Found</button>
    </div>

    <div class="form-section">
        <input type="text" id="title" placeholder="Item Name">
        <textarea id="description" placeholder="Description"></textarea>
        <input type="text" id="location" placeholder="Location">
        <input type="text" id="contact" placeholder="Contact Number">

        <input type="file" id="image" accept="image/*" onchange="previewImage()">
        <img id="preview" class="preview">

        <button class="submit-btn" onclick="submitItem()">Submit</button>
    </div>

    <div class="cards" id="cards"></div>
</div>

<script>
// 🔥 RESET STORAGE ON LOAD (only runs once)
if (!localStorage.getItem("resetDone")) {
    localStorage.removeItem("lostfound"); // clear all items
    localStorage.setItem("resetDone", "true");
}

// USER ID SYSTEM
let userId = localStorage.getItem("userId");
if (!userId) {
    userId = "user_" + Math.random().toString(36).substr(2, 9);
    localStorage.setItem("userId", userId);
}

let currentType = "lost";
let imageData = "";

function setType(type) {
    currentType = type;
    document.getElementById("lostBtn").classList.remove("active");
    document.getElementById("foundBtn").classList.remove("active");
    document.getElementById(type + "Btn").classList.add("active");
}

function previewImage() {
    const file = document.getElementById("image").files[0];
    const reader = new FileReader();

    reader.onload = function(e) {
        imageData = e.target.result;
        let preview = document.getElementById("preview");
        preview.src = imageData;
        preview.style.display = "block";
    };

    if (file) reader.readAsDataURL(file);
}

function submitItem() {
    let title = document.getElementById("title").value;
    if (!title) {
        alert("Enter item name");
        return;
    }

    let item = {
        id: Date.now(),
        userId: userId,
        title,
        desc: document.getElementById("description").value,
        location: document.getElementById("location").value,
        contact: document.getElementById("contact").value,
        type: currentType,
        image: imageData,
        date: new Date().toLocaleString()
    };

    let items = JSON.parse(localStorage.getItem("lostfound")) || [];
    items.push(item);
    localStorage.setItem("lostfound", JSON.stringify(items));

    alert("Submitted!");

    document.getElementById("title").value = "";
    document.getElementById("description").value = "";
    document.getElementById("location").value = "";
    document.getElementById("contact").value = "";
    document.getElementById("image").value = "";
    document.getElementById("preview").style.display = "none";
    imageData = "";

    displayItems();
}

function deleteItem(id) {
    let items = JSON.parse(localStorage.getItem("lostfound")) || [];
    items = items.filter(item => item.id !== id);
    localStorage.setItem("lostfound", JSON.stringify(items));
    displayItems();
}

function displayItems() {
    let items = JSON.parse(localStorage.getItem("lostfound")) || [];
    let container = document.getElementById("cards");
    container.innerHTML = "";

    if (items.length === 0) {
        container.innerHTML = "<p style='text-align:center;'>No items reported yet.</p>";
        return;
    }

    items.reverse().forEach(item => {
        let div = document.createElement("div");
        div.className = "card " + (item.type === "found" ? "found" : "");

        let deleteBtn = "";
        if (item.userId === userId) {
            deleteBtn = `<button class="delete-btn" onclick="deleteItem(${item.id})">Delete My Item</button>`;
        }

        div.innerHTML = `
            <h3>${item.title}</h3>
            <p>${item.desc}</p>
            <p><b>📍</b> ${item.location}</p>
            <p><b>📞</b> ${item.contact}</p>
            ${item.image ? `<img src="${item.image}">` : ""}
            <p class="small">${item.type.toUpperCase()} • ${item.date}</p>
            ${deleteBtn}
        `;

        container.appendChild(div);
    });
}

displayItems();
</script>

</body>
</html>